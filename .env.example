# Copy to server/.env for local runs. On Render set these as service env vars.
# NEVER commit the real .env — it is gitignored.

# Telegram bot token from @BotFather
BOT_TOKEN=000000000:replace-with-real-token

# MongoDB Atlas connection string (with a real user/password)
MONGO_URI=mongodb+srv://USER:PASSWORD@esimworker.xxxxx.mongodb.net/

# Database name inside the cluster
DB_NAME=esimworker

# Long random string — part of the webhook URL so only Telegram can reach it
WEBHOOK_SECRET=replace-with-a-long-random-string

# Comma-separated Telegram IDs allowed to run admin bot commands
ADMIN_IDS=123456789

# Hours offset from UTC for "today" / timestamps (3 = Moscow)
TZ_OFFSET_HOURS=3

# Public https URL of this server. On Render leave empty — RENDER_EXTERNAL_URL
# is provided automatically. Set it manually only on other hosts.
PUBLIC_URL=
